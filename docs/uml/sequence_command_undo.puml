@startuml
title Command Execute & Undo

actor User
participant DevicesFacade
participant CommandManager
participant DeviceGroup as BedroomGroup
participant Light1
participant Light2

User -> DevicesFacade : executeCommand(TurnOffAllBedroomLights)
DevicesFacade -> CommandManager : enqueue(TurnOffAllBedroomLights)
CommandManager -> BedroomGroup : execute()
BedroomGroup -> Light1 : turnOff()
Light1 -> CommandManager : ack
BedroomGroup -> Light2 : turnOff()
Light2 -> CommandManager : ack
CommandManager -> CommandManager : pushHistory(command)

... later ...
User -> DevicesFacade : undoLast()
DevicesFacade -> CommandManager : undoLast()
CommandManager -> BedroomGroup : undoTurnOffAll()
BedroomGroup -> Light1 : turnOn()
BedroomGroup -> Light2 : turnOn()
@enduml
