@startuml
title Mode Switch

actor User
participant DevicesFacade
participant AutomationEngine
participant CommandManager

User -> DevicesFacade : setMode(EnergySavingMode)
DevicesFacade -> AutomationEngine : setMode(EnergySavingMode)
AutomationEngine -> AutomationEngine : mode.apply(engine, context)
AutomationEngine -> CommandManager : enqueue(commands to adjust devices)
CommandManager -> DevicesHub : execute adjustments
@enduml
